# Django settings
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.*

# Database configuration
DB_ENGINE=django.db.backends.postgresql
DB_NAME=ministry_health_it
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# Alternative SQLite (uncomment for development)
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=db.sqlite3

# LDAP/Active Directory Configuration
LDAP_SERVER_URI=ldap://your-ad-server.local
LDAP_BIND_DN=cn=admin,dc=ministry,dc=local
LDAP_BIND_PASSWORD=your_ldap_password
LDAP_USER_SEARCH_BASE=ou=Users,dc=ministry,dc=local
LDAP_GROUP_SEARCH_BASE=ou=Groups,dc=ministry,dc=local
LDAP_ENABLED=False

# Application settings
TIME_ZONE=Africa/Johannesburg
LANGUAGE_CODE=en-us

# Security
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SESSION_TIMEOUT=3600

# Backup Configuration
BACKUP_ENABLED=True
BACKUP_SCHEDULE=daily
BACKUP_TIME=02:00
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/media/backups/
BACKUP_DESTINATION=local

# Email Configuration (optional, for notifications)
EMAIL_BACKEND=django.core.mail.backends.locmem.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
